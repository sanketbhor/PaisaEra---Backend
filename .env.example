# ==============================================================
# PaisaEra Backend — Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit .env — only .env.example goes in git.
# ==============================================================

# ---------- App ----------
APP_NAME=PaisaEra
APP_ENV=development          # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# ---------- Database ----------
# Local dev via docker-compose uses these defaults automatically.
DATABASE_URL=postgresql+psycopg2://paisaera:paisaera@db:5432/paisaera

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Auth / Security ----------
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-real-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------- OTP ----------
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_RESENDS=5
OTP_RATE_LIMIT_PER_HOUR=5

# SMS provider — leave blank to use the console/log provider for local dev.
# Fill these in when you have a real MSG91 or Twilio account.
SMS_PROVIDER=console          # console | msg91 | twilio
MSG91_API_KEY=
MSG91_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------- Google Sign-In (secondary auth method) ----------
GOOGLE_CLIENT_ID=

# ---------- AI Providers ----------
# Set at least one. If none are set, the AI Gateway falls back to the
# static Hinglish template bank automatically — the API still works.
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
AI_DEFAULT_PROVIDER=openai    # openai | gemini | openrouter
AI_DEFAULT_MODEL=gpt-4o-mini

# ---------- AI Gateway — usage limits ----------
AI_FREE_TIER_DAILY_LIMIT=30
AI_PRO_TIER_DAILY_LIMIT=100
AI_MAX_RESPONSE_TOKENS=150

# ---------- Celery ----------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- Payment Provider (Premium/Pro plan billing — not yet wired) ----------
# Flagged as an open item in the Security & Access Document.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:19006,http://localhost:3000
